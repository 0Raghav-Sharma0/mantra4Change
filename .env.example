# =============================================================================
# Mantra4Change — environment template
# Copy per service:
#   cp apps/server/.env.example apps/server/.env
#   cp apps/client/.env.example apps/client/.env
#   cp apps/analytics/.env.example apps/analytics/.env
# =============================================================================

# --- Server (apps/server/.env) ---
# PORT=5000
# MONGODB_URI=mongodb://127.0.0.1:27017/mantra4change
# ANALYTICS_SERVICE_URL=http://localhost:8000

# --- Client (apps/client/.env) ---
# VITE_API_BASE_URL=http://localhost:5000

# --- Analytics (apps/analytics/.env) ---
# ANALYTICS_PORT=8000
# NODE_SERVER_URL=http://localhost:5000
