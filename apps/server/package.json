{
  "name": "@mantra4change/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "verify": "tsx src/scripts/verify.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "node --import tsx --test 'src/programIntelligence/**/*.test.ts' 'src/services/**/*.test.ts'",
    "test:integration": "RUN_INTEGRATION_TESTS=1 node --import tsx --test src/integration/evaluation.integration.test.ts"
  },
  "dependencies": {
    "@mantra4change/shared-types": "*",
    "cors": "^2.8.5",
    "ioredis": "^5.3.2",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.22.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
